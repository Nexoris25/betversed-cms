{
  "kind": "collectionType",
  "collectionName": "bookmakers",
  "info": {
    "singularName": "bookmaker",
    "pluralName": "bookmakers",
    "displayName": "Main Review"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "maxLength": 80,
      "required": true
    },
    "slug": {
      "type": "uid",
      "required": true
    },
    "countryCode": {
      "type": "enumeration",
      "enum": [
        "ng",
        "gh",
        "ke",
        "za"
      ]
    },
    "isFeatured": {
      "type": "boolean"
    },
    "lastUpdated": {
      "type": "date"
    },
    "seoMeta": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "heroSection": {
      "type": "component",
      "component": "site-review.hero-block",
      "repeatable": false
    },
    "summaryBox": {
      "type": "component",
      "component": "site-review.editorial-summary",
      "repeatable": false
    },
    "mainContent": {
      "type": "dynamiczone",
      "components": [
        "shared.rich-text",
        "shared.publisher-info",
        "shared.badge-label",
        "shared.button-link",
        "shared.callout-box"
      ]
    },
    "FAQs": {
      "type": "component",
      "component": "shared.faqs-content",
      "repeatable": false
    },
    "evidenceHub": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    }
  }
}
